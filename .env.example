# ─────────────────────────────────────────────────────────────
# Dispatch Agent — environment template
# Copy to .env.local and fill in values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Vapi (Voice platform) ──
# Get from https://dashboard.vapi.ai → Settings → API Keys
# Public Key: safe to expose in browser (used by Vapi Web SDK)
# Private Key: server-only (used by webhook verification & API calls)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=

# Per-vertical assistant IDs.
# To create one for a new vertical:
#   1. Run `npm run sync:<vertical>` with VAPI_PRIVATE_KEY set.
#      The script POSTs /assistant when the corresponding *_ASSISTANT_ID
#      env var is empty, then prints the new UUID.
#   2. Paste the printed UUID below AND in your hosting provider's env vars.
#   3. Re-deploy. The voice tab will light up for that vertical.
#   4. Subsequent `npm run sync:<vertical>` runs PATCH the existing assistant
#      idempotently — safe to run repeatedly to push prompt/tool changes.
NEXT_PUBLIC_VAPI_HVAC_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_PLUMBER_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_ELECTRICIAN_ASSISTANT_ID=
NEXT_PUBLIC_VAPI_DENTAL_ASSISTANT_ID=

# Optional: explicit webhook URL to register with Vapi (e.g. ngrok tunnel for
# local dev, or a staging URL different from NEXT_PUBLIC_APP_URL). Defaults to
# `${NEXT_PUBLIC_APP_URL}/api/vapi-webhook`.
# VAPI_SERVER_URL=https://abcd1234.ngrok-free.app/api/vapi-webhook

# ── OpenRouter (LLM) ──
# Get from https://openrouter.ai/keys
# Used by Vapi via Provider Keys integration; we keep here for local scripts.
OPENROUTER_API_KEY=

# Model selection (override per environment)
# Free fallback (slightly slower):       z-ai/glm-4.5-air:free
# Auto-route (resilient, picks free):    openrouter/free
# Paid, fast, reliable for demos:        openai/gpt-4o-mini   (~$0.001/call)
# Premium reasoning:                     anthropic/claude-haiku-4.5
OPENROUTER_MODEL=z-ai/glm-4.5-air:free

# ── Supabase (Phase 2+) ──
# Free tier: https://supabase.com → New Project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
