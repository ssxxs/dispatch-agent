# ─────────────────────────────────────────────────────────────
# Dispatch Agent — environment template
# Copy to .env.local and fill in values. Never commit .env.local.
# ─────────────────────────────────────────────────────────────

# ── Vapi (Voice platform) ──
# Get from https://dashboard.vapi.ai → Settings → API Keys
# Public Key: safe to expose in browser (used by Vapi Web SDK)
# Private Key: server-only (used by webhook verification & API calls)
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
VAPI_PRIVATE_KEY=

# Assistant ID — created in Vapi Dashboard or via /scripts/create-assistant.ts
# Paste the assistant UUID after creation
NEXT_PUBLIC_VAPI_HVAC_ASSISTANT_ID=

# ── OpenRouter (LLM) ──
# Get from https://openrouter.ai/keys
# Used by Vapi via Provider Keys integration; we keep here for local scripts.
OPENROUTER_API_KEY=

# Model selection (override per environment)
# Dev (free):   google/gemini-2.0-flash-exp:free
# Prod (cheap): openai/gpt-4o-mini
# Prod (best):  anthropic/claude-haiku-4.5
OPENROUTER_MODEL=google/gemini-2.0-flash-exp:free

# ── Supabase (Phase 2+) ──
# Free tier: https://supabase.com → New Project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── App ──
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
